{
  "expo": {
    "name": "abdalla",
    "slug": "abdalla",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000,
      "url": "https://u.expo.dev/deefeb67-a065-4240-8a3f-a3f2ed6e6c4c"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mastajazz.abdalla",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Jahzeen uses your location to set your service address and pin nearby bookings accurately."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mastajazz.abdalla",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Abdalla",
      "shortName": "Abdalla",
      "themeColor": "#0E8E4E",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "eas": {
        "projectId": "deefeb67-a065-4240-8a3f-a3f2ed6e6c4c"
      }
    },
    "owner": "masta-jazz"
  }
}
